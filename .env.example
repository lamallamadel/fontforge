# ── AIFont environment variables ──────────────────────────────────────────────
# Copy this file to .env and fill in the values before starting Docker.
#
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=aifont
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aifont

# ── Redis ──────────────────────────────────────────────────────────────────────
# Used only in production (docker-compose.prod.yml)
REDIS_PASSWORD=changeme_redis

# ── Application ────────────────────────────────────────────────────────────────
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-secure-random-secret-key

# Comma-separated list of allowed CORS origins for the API
# e.g. CORS_ORIGINS=http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000

# Number of Uvicorn worker processes (production only)
API_WORKERS=4

# ── AI / LLM ───────────────────────────────────────────────────────────────────
# Provide your LLM API key here (used by AI agents)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
